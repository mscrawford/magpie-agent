# Temporary files
*.tmp
*.bak
*~

# Editor files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Session logs (can be regenerated)
session_logs/scratch_*
session_logs/temp_*
*.backup

# Claude Code settings (copied from parent, user-specific)
.claude/settings.local.json

# Validation reports (now written into .cache/validation_reports/)
validation_report_*.txt

# Local cache: SHA-pinned R package clones (e.g. magpie4) + validator reports
.cache/

# Python bytecode
__pycache__/
*.pyc
